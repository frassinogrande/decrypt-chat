# Copy to .env and adjust for your environment.
# Base URL used when generating shareable chat links (defaults to https://decrypt.chat
# if unset — see src/lib/config/settings.ts). For LAN testing on another device, set this
# to your machine's local address, e.g. https://192.168.x.x:5173
#VITE_SHARE_BASE_URL=https://decrypt.chat
